{
  "version": 2,
  "functions": {
    "api/alumnos.js":                  { "maxDuration": 10 },
    "api/carga-masiva-fotos.js":       { "maxDuration": 30 },
    "api/dashboard.js":                { "maxDuration": 10 },
    "api/expediente.js":               { "maxDuration": 10 },
    "api/ficha-publica.js":            { "maxDuration": 10 },
    "api/foto-alumno.js":              { "maxDuration": 30 },
    "api/importar-calificaciones.js":  { "maxDuration": 60 },
    "api/login.js":                    { "maxDuration": 10 },
    "api/logs.js":                     { "maxDuration": 10 },
    "api/personal.js":                 { "maxDuration": 10 },
    "api/reportes.js":                 { "maxDuration": 10 },
    "api/usuarios.js":                 { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn-icons-png.flaticon.com https://dugxnbuwdkgokulhkpgy.supabase.co; connect-src 'self' https://dugxnbuwdkgokulhkpgy.supabase.co https://fichas-descriptivas.vercel.app; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
